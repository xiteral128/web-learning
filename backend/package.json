{
  "name": "taobao-backend",
  "version": "1.0.0",
  "description": "淘宝商城后端API服务",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "cd ../database && node init.js init",
    "reset-db": "cd ../database && node init.js reset",
    "test-db": "cd ../database && node db.js test",
    "test": "echo \"运行测试: npm run test-db\"",
    "setup": "npm install && npm run init-db"
  },
  "keywords": ["taobao", "ecommerce", "api", "backend"],
  "author": "OpenClaw AI Assistant",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}